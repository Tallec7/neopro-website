---
import Logo from '@/components/icons/Logo.astro';
import SocialIcons from '@/components/icons/SocialIcons.astro';
import Button from '@/components/Button.astro';

const footerLinks = [
  { label: 'La solution', href: '/solution' },
  { label: 'Les offres', href: '/offres' },
  { label: 'Qui sommes-nous ?', href: '/qui-sommes-nous' },
];

const year = new Date().getFullYear();

const legalLinks = [
  { label: 'Mentions légales', href: '/mentions-legales' },
  { label: 'Politique de confidentialité', href: '/politique-de-confidentialite' },
];
---

<footer class="bg-neo-dark-bg text-white">
  <div class="max-w-[1200px] mx-auto px-6 md:px-[120px] pt-[60px] md:pt-[80px] pb-[60px] md:pb-[96px]">
    <!-- Row 1: Logo + Social icons -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
      <a href="/">
        <Logo variant="white" class="h-[34px] w-auto" />
      </a>
      <div class="flex gap-[10px]">
        <a href="https://www.instagram.com/neopro_fr/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="text-neo-green hover:text-neo-green-dark transition-colors">
          <SocialIcons platform="instagram" size={25} />
        </a>
        <a href="https://www.linkedin.com/company/neopro-communication/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-neo-green hover:text-neo-green-dark transition-colors">
          <SocialIcons platform="linkedin" size={22} />
        </a>
      </div>
    </div>

    <!-- Divider — green line -->
    <div class="h-[2px] bg-neo-green my-8" />

    <!-- Row 2: Nav links + CTAs -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
      <div class="flex flex-wrap gap-[28px] items-center text-[16px] text-white">
        {footerLinks.map((link) => (
          <a href={link.href} class="hover:text-neo-green transition-colors">
            {link.label}
          </a>
        ))}
      </div>
      <div class="flex flex-wrap gap-[16px] items-center">
        <Button href="/devis" variant="green">
          Obtenez un devis
        </Button>
        <Button href="#contact" variant="black">
          Planifier une démo
        </Button>
        <a href="https://neopro-admin.kalonpartners.bzh" target="_blank" rel="noopener noreferrer" class="text-[16px] font-medium text-white hover:text-neo-green transition-colors">
          Espace Club
        </a>
      </div>
    </div>

    <!-- Row 3: Legal links + Copyright -->
    <div class="h-[1px] bg-[rgba(255,255,255,0.15)] mt-8 mb-6" />
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div class="flex flex-wrap gap-[20px] text-[13px] text-[rgba(255,255,255,0.5)]">
        {legalLinks.map((link) => (
          <a href={link.href} class="hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>
      <p class="text-[13px] text-[rgba(255,255,255,0.4)]">
        &copy; {year} Neopro. Tous droits réservés.
      </p>
    </div>
  </div>
</footer>
