---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DevisForm from '@/components/DevisForm.tsx';

// ── Sanity (optionnel) ────────────────────────────────────────────
import { sanityClient } from '@/lib/sanity';
import { devisPageQuery } from '@/lib/queries';

let pageData: any = null;
try {
  if (sanityClient) {
    pageData = await sanityClient.fetch(devisPageQuery);
  }
} catch {}

// ── SEO ───────────────────────────────────────────────────────────
const title = pageData?.seoTitle || 'Obtenez votre devis';
const description = pageData?.seoDescription ||
  'Obtenez une estimation personnalisée pour votre solution de régie digitale Neopro. Standard, Autonomie ou Premium.';
---

<BaseLayout title={title} description={description}>
  <DevisForm client:load />
</BaseLayout>
