        <!-- TODO: Remplacer par la forme juridique exacte (SAS, SARL, etc.) -->
        Forme juridique : [À compléter]<br />
        Capital social : [À compléter]<br />
        Siège social : Nantes, France<br />
        RCS : [À compléter]<br />
        SIRET : [À compléter]<br />
        Numéro de TVA : [À compléter]<br />
        Email : <a href="mailto:contact@neopro-communication.fr">contact@neopro-communication.fr</a><br />
        Directeur de la publication : [À compléter]
